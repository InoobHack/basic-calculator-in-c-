	int q;
	cout << "What number do u want to divide(seperated by space):  ";
    
	while(true) {
	 cin >> w >> q;
		if(cin.fail()) {
			cin.clear();
			cin.ignore(1000, '\n');
			cout << "Only numbers allowed\n";
			return;
		} else {
			cin.ignore(1000, '\n');
			break;
		}
	}
	
	float result4 = w / q;
